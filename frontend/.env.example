# Frontend Environment Variables for Web/Vercel Deployment
# Copy this file to .env and fill in your values

# Backend API URL - REQUIRED for web deployment
# Set this to your deployed backend URL (e.g., Railway, Render, Fly.io)
EXPO_PUBLIC_BACKEND_URL=https://your-backend-api.com

# Development only (do not use in production)
# EXPO_TUNNEL_SUBDOMAIN=your-app-name
# EXPO_PACKAGER_HOSTNAME=https://your-app-name.preview.emergentagent.com
