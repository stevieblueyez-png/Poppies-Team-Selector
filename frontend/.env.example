# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (change to your deployed backend URL in production)
EXPO_PUBLIC_BACKEND_URL=https://your-deployed-backend.com

# Expo Tunnel Configuration (for development only)
# These are auto-configured by Emergent, do not modify in production
# EXPO_TUNNEL_SUBDOMAIN=your-app-name
# EXPO_PACKAGER_HOSTNAME=https://your-app-name.preview.emergentagent.com
